<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Andre Shendra — Marketing & Events Strategist</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#080808;--fg:#EDECE8;--gold:#C8A84B;
  --muted:rgba(237,236,232,0.5);--border:rgba(237,236,232,0.1);
}
html{scroll-behavior:smooth;}
body{font-family:'Space Grotesk',sans-serif;background:var(--bg);color:var(--fg);overflow-x:hidden;cursor:none;}
#cur{position:fixed;width:12px;height:12px;background:var(--fg);border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:difference;}
#cur-ring{position:fixed;width:40px;height:40px;border:1px solid rgba(237,236,232,0.5);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .2s,height .2s;}
.dot-grid{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:radial-gradient(rgba(237,236,232,0.07) 1px,transparent 1px);background-size:32px 32px;}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:1.2rem 3rem;background:rgba(8,8,8,0.88);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
.nav-left{display:flex;align-items:center;gap:1.5rem;}
.nav-logo{font-family:"Bebas Neue",sans-serif;font-size:1.1rem;letter-spacing:.15em;}
.nav-time{font-size:.72rem;color:var(--muted);letter-spacing:.1em;font-variant-numeric:tabular-nums;}
.nav-avail{display:flex;align-items:center;gap:.4rem;font-size:.68rem;letter-spacing:.12em;color:rgba(61,186,111,0.9);text-transform:uppercase;}
.nav-dot{width:6px;height:6px;background:#3DBA6F;border-radius:50%;animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.3;}}
.nav-right{display:flex;align-items:center;gap:2rem;}
.nav-links{display:flex;gap:1.8rem;}
.nav-links a{font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .3s;}
.nav-links a:hover{color:var(--fg);}
.nav-hire{border:1px solid var(--fg);color:var(--fg);padding:.5rem 1.5rem;border-radius:2rem;font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;transition:all .3s;}
.nav-hire:hover{background:var(--fg);color:var(--bg);}

/* ======= HERO — FULL COVER ======= */
.hero{
  position:relative;z-index:1;
  width:100%;height:100vh;
  overflow:hidden;
  display:flex;flex-direction:column;
  justify-content:flex-end;
}
.hero-cover{
  position:absolute;inset:0;
  background-image:url("data:image/png;base64,");
  background-size:cover;
  background-position:center top;
  filter:brightness(0.45);
  z-index:0;
}
.hero-overlay{
  position:absolute;inset:0;z-index:1;
  background:linear-gradient(to bottom, rgba(8,8,8,0.1) 0%, rgba(8,8,8,0.0) 40%, rgba(8,8,8,0.85) 100%);
}
.hero-content{
  position:relative;z-index:2;
  padding:0 3rem 3rem;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:.5rem;
  font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;
  color:var(--gold);margin-bottom:1.5rem;
}
.hero-tag::before{content:"";width:24px;height:1px;background:var(--gold);}
.hero-title{
  font-family:"Bebas Neue",sans-serif;
  font-size:clamp(5rem,14vw,14rem);
  line-height:.88;letter-spacing:-.01em;
  color:var(--fg);
}
.hero-title .stroke{-webkit-text-stroke:1.5px rgba(237,236,232,.35);color:transparent;}
.hero-bottom{
  display:grid;grid-template-columns:1fr 1fr 1fr;
  border-top:1px solid var(--border);
  position:relative;z-index:2;
  background:rgba(8,8,8,0.7);
  backdrop-filter:blur(10px);
}
.hero-bottom-cell{padding:1.5rem 3rem;border-right:1px solid var(--border);display:flex;flex-direction:column;gap:.3rem;}
.hero-bottom-cell:last-child{border-right:none;justify-content:center;align-items:flex-end;}
.hbc-label{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);}
.hbc-value{font-size:.9rem;color:var(--fg);font-weight:500;}
.hero-desc{font-size:.88rem;color:rgba(237,236,232,0.8);line-height:1.8;max-width:320px;}
.hero-cta{display:flex;gap:1rem;align-items:center;}
.btn-primary{background:var(--fg);color:var(--bg);padding:.7rem 2rem;border-radius:2rem;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;font-weight:600;transition:opacity .3s;}
.btn-primary:hover{opacity:.85;}
.btn-ghost{color:rgba(237,236,232,0.8);font-size:.78rem;letter-spacing:.08em;text-decoration:none;display:flex;align-items:center;gap:.4rem;transition:color .3s;}
.btn-ghost:hover{color:var(--fg);}

/* STATS */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--border);position:relative;z-index:1;}
.stat-cell{padding:2.5rem 3rem;border-right:1px solid var(--border);display:flex;flex-direction:column;gap:.4rem;}
.stat-cell:last-child{border-right:none;}
.stat-n{font-family:"Bebas Neue",sans-serif;font-size:3.8rem;line-height:1;color:var(--fg);}
.stat-l{font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);}

/* SECTION COMMON */
section{position:relative;z-index:1;}
.sec-header{display:flex;align-items:baseline;justify-content:space-between;padding:2.5rem 3rem 2rem;border-bottom:1px solid var(--border);}
.sec-num{font-size:.65rem;letter-spacing:.25em;color:var(--muted);}
.sec-title{font-family:"Bebas Neue",sans-serif;font-size:clamp(3rem,8vw,7rem);letter-spacing:.02em;line-height:1;}
.sec-tag{font-size:.65rem;letter-spacing:.15em;color:var(--muted);text-transform:uppercase;}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--border);}
.about-left{padding:4rem 3rem;border-right:1px solid var(--border);}
.about-img{
  width:100%;height:480px;overflow:hidden;margin-bottom:2rem;position:relative;
}
.about-img img{
  width:100%;height:100%;
  object-fit:cover;
  object-position:center 60%;
  filter:grayscale(8%);
  transform:scale(1.15);
}
.about-img-label{position:absolute;bottom:1rem;left:1rem;font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(237,236,232,.4);}
.about-right{padding:4rem 3rem;display:flex;flex-direction:column;gap:2.5rem;}
.about-headline{font-family:"Bebas Neue",sans-serif;font-size:clamp(2.5rem,5vw,4rem);line-height:1.05;letter-spacing:.02em;color:var(--fg);}
.about-body p{font-size:1rem;color:rgba(237,236,232,.85);line-height:1.9;margin-bottom:1.2rem;font-weight:300;}
.about-tags{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.5rem;}
.a-tag{border:1px solid rgba(237,236,232,.2);color:rgba(237,236,232,.75);padding:.3rem .85rem;border-radius:2rem;font-size:.7rem;letter-spacing:.06em;transition:all .3s;}
.a-tag:hover{border-color:var(--fg);color:var(--fg);}
.skills{display:grid;gap:0;border-top:1px solid var(--border);margin-top:1rem;}
.sk-row{display:flex;justify-content:space-between;align-items:center;padding:1rem 0;border-bottom:1px solid var(--border);font-size:.88rem;color:rgba(237,236,232,.85);}
.sk-bar{width:130px;height:2px;background:rgba(237,236,232,.1);}
.sk-fill{height:100%;background:var(--fg);}

/* WHAT I DO */
.wid-grid{display:grid;grid-template-columns:repeat(3,1fr);}
.wid-box{padding:3rem 2.5rem;border-right:1px solid var(--border);transition:background .4s;}
.wid-box:last-child{border-right:none;}
.wid-box:hover{background:rgba(237,236,232,.03);}
.wid-dots{display:flex;gap:5px;margin-bottom:2.5rem;}
.wd{width:7px;height:7px;border-radius:50%;background:rgba(237,236,232,.12);}
.wd.on{background:var(--fg);}
.wid-icon{font-size:1.8rem;margin-bottom:1.5rem;display:block;}
.wid-title{font-family:"Bebas Neue",sans-serif;font-size:1.6rem;letter-spacing:.06em;margin-bottom:1rem;color:var(--fg);}
.wid-desc{font-size:.85rem;color:rgba(237,236,232,.78);line-height:1.85;font-weight:300;}
.wid-list{margin-top:1.2rem;display:flex;flex-direction:column;gap:.5rem;}
.wid-list span{font-size:.75rem;color:rgba(237,236,232,.58);display:flex;align-items:center;gap:.5rem;}
.wid-list span::before{content:"—";color:rgba(237,236,232,.3);}

/* PROJECTS */
.proj-grid{display:grid;grid-template-columns:1fr 1fr;}
.proj-card{position:relative;height:420px;overflow:hidden;border-right:1px solid var(--border);border-bottom:1px solid var(--border);text-decoration:none;display:block;cursor:none;}
.proj-card:nth-child(even){border-right:none;}
.proj-card:nth-child(3),.proj-card:nth-child(4){border-bottom:none;}
.proj-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .8s ease,filter .5s;filter:brightness(.25) saturate(.6);}
.proj-card:hover .proj-bg{transform:scale(1.07);filter:brightness(.15) saturate(.4);}
.proj-bg-1{background:linear-gradient(145deg,#1a0800,#2d1000,#080808);}
.proj-bg-2{background:linear-gradient(145deg,#00081a,#001020,#080808);}
.proj-bg-3{background:linear-gradient(145deg,#0a0015,#14002a,#080808);}
.proj-bg-4{background:linear-gradient(145deg,#001500,#002800,#080808);}
.proj-over{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:3rem;text-align:center;}
.proj-num{font-size:.62rem;letter-spacing:.3em;color:rgba(237,236,232,.25);margin-bottom:1.5rem;transition:color .3s;}
.proj-card:hover .proj-num{color:var(--gold);}
.proj-name{font-family:"Bebas Neue",sans-serif;font-size:clamp(1.8rem,3.5vw,2.8rem);line-height:1.05;letter-spacing:.04em;color:var(--fg);text-align:center;transition:transform .4s;}
.proj-name span{display:block;font-size:.8em;color:rgba(237,236,232,.5);}
.proj-card:hover .proj-name{transform:translateY(-10px);}
.proj-arr{font-size:1.4rem;margin-top:1.5rem;color:rgba(237,236,232,0);transition:color .4s,transform .4s;}
.proj-card:hover .proj-arr{color:var(--fg);transform:translate(4px,-4px);}

/* EXPERIENCE */
.exp-list{border-top:1px solid var(--border);}
.exp-row{display:grid;grid-template-columns:60px 1fr auto;gap:2.5rem;padding:2.5rem 3rem;border-bottom:1px solid var(--border);transition:background .3s;align-items:start;}
.exp-row:hover{background:rgba(237,236,232,.02);}
.exp-idx{font-size:.62rem;letter-spacing:.18em;color:var(--muted);padding-top:.3rem;}
.exp-role{font-size:1.05rem;font-weight:600;color:var(--fg);margin-bottom:.25rem;}
.exp-co{font-size:.8rem;color:var(--gold);letter-spacing:.05em;margin-bottom:.8rem;}
.exp-desc{font-size:.85rem;color:rgba(237,236,232,.75);line-height:1.85;font-weight:300;max-width:520px;}
.exp-tags{display:flex;flex-wrap:wrap;gap:.3rem;margin-top:.9rem;}
.e-tag{font-size:.63rem;letter-spacing:.07em;color:rgba(237,236,232,.55);border:1px solid rgba(237,236,232,.18);padding:.18rem .55rem;border-radius:.2rem;}
.exp-date{font-size:.7rem;color:var(--muted);text-align:right;white-space:nowrap;letter-spacing:.06em;}

/* EDUCATION */
.edu-grid{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--border);}
.edu-card{padding:4rem 3rem;border-right:1px solid var(--border);position:relative;overflow:hidden;transition:background .4s;}
.edu-card:last-child{border-right:none;}
.edu-card:hover{background:rgba(237,236,232,.02);}
.edu-yr{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:1.5rem;}
.edu-deg{font-family:"Bebas Neue",sans-serif;font-size:2.2rem;letter-spacing:.04em;line-height:1.05;margin-bottom:.5rem;color:var(--fg);}
.edu-field{font-size:.9rem;color:var(--gold);margin-bottom:1.2rem;letter-spacing:.03em;}
.edu-school{font-size:.85rem;color:rgba(237,236,232,.68);line-height:1.7;}
.edu-badge{display:inline-block;margin-top:1.5rem;border:1px solid rgba(237,236,232,.22);color:rgba(237,236,232,.62);padding:.3rem .8rem;border-radius:2rem;font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;}
.edu-ghost{position:absolute;bottom:1.5rem;right:2rem;font-family:"Bebas Neue",sans-serif;font-size:7rem;line-height:1;color:rgba(237,236,232,.03);pointer-events:none;}
.edu-note{font-size:.75rem;color:rgba(237,236,232,.35);line-height:1.7;margin-top:1.2rem;}

/* TESTIMONIALS */
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);border-top:1px solid var(--border);}
.testi-card{padding:3rem 2.5rem;border-right:1px solid var(--border);transition:background .3s;}
.testi-card:last-child{border-right:none;}
.testi-card:hover{background:rgba(237,236,232,.02);}
.testi-q{font-size:2.5rem;color:var(--gold);line-height:1;margin-bottom:1rem;}
.testi-txt{font-size:.87rem;color:rgba(237,236,232,.78);line-height:1.9;font-style:italic;margin-bottom:2rem;font-weight:300;}
.testi-author{display:flex;align-items:center;gap:.9rem;}
.testi-av{width:40px;height:40px;border-radius:50%;background:rgba(237,236,232,.08);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.7rem;color:var(--muted);}
.testi-name{font-size:.85rem;font-weight:600;color:var(--fg);}
.testi-role{font-size:.7rem;color:var(--muted);}

/* CONTACT */
.contact-wrap{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--border);min-height:65vh;}
.contact-left{padding:5rem 3rem;border-right:1px solid var(--border);display:flex;flex-direction:column;justify-content:space-between;}
.contact-big{font-family:"Bebas Neue",sans-serif;font-size:clamp(3.5rem,8vw,8rem);line-height:.92;letter-spacing:.01em;margin-bottom:2rem;}
.contact-sub{font-size:.9rem;color:rgba(237,236,232,.68);line-height:1.8;max-width:340px;}
.contact-right{padding:5rem 3rem;display:flex;flex-direction:column;justify-content:space-between;}
.c-links{display:flex;flex-direction:column;}
.c-link{display:flex;align-items:center;justify-content:space-between;padding:1.4rem 0;border-bottom:1px solid var(--border);text-decoration:none;color:rgba(237,236,232,.82);transition:color .3s;font-size:.9rem;}
.c-link:hover{color:var(--fg);}
.c-link-label{font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:.2rem;}
.c-arr{font-size:1.1rem;transition:transform .3s;}
.c-link:hover .c-arr{transform:translate(3px,-3px);}
.c-btns{display:flex;gap:1rem;flex-wrap:wrap;margin-top:2.5rem;}
.c-btn-p{background:var(--fg);color:var(--bg);padding:.9rem 2.2rem;border-radius:2rem;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;font-weight:600;transition:opacity .3s;}
.c-btn-p:hover{opacity:.85;}
.c-btn-g{border:1px solid rgba(237,236,232,.3);color:rgba(237,236,232,.82);padding:.9rem 2.2rem;border-radius:2rem;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;transition:all .3s;}
.c-btn-g:hover{border-color:var(--fg);color:var(--fg);}

footer{display:flex;align-items:center;justify-content:space-between;padding:1.5rem 3rem;border-top:1px solid var(--border);position:relative;z-index:1;}
footer p{font-size:.7rem;color:var(--muted);letter-spacing:.08em;}

@media(max-width:768px){
  nav{padding:1rem 1.5rem;}
  .nav-links{display:none;}
  .hero-content{padding:0 1.5rem 2rem;}
  .hero-bottom{grid-template-columns:1fr;}
  .hero-bottom-cell{border-right:none;border-bottom:1px solid var(--border);padding:1.2rem 1.5rem;}
  .stats-row{grid-template-columns:1fr 1fr;}
  .stat-cell{border-bottom:1px solid var(--border);}
  .sec-header{padding:2rem 1.5rem 1.5rem;}
  .about-grid,.edu-grid,.contact-wrap{grid-template-columns:1fr;}
  .about-left,.edu-card,.contact-left{border-right:none;border-bottom:1px solid var(--border);}
  .about-left,.about-right,.contact-left,.contact-right,.edu-card{padding:3rem 1.5rem;}
  .wid-grid{grid-template-columns:1fr;}
  .wid-box{border-right:none;border-bottom:1px solid var(--border);}
  .proj-grid{grid-template-columns:1fr;}
  .proj-card{border-right:none;height:300px;}
  .exp-row{grid-template-columns:1fr;gap:.5rem;padding:2rem 1.5rem;}
  .testi-grid{grid-template-columns:1fr;}
  .testi-card{border-right:none;border-bottom:1px solid var(--border);}
  footer{padding:1.2rem 1.5rem;flex-direction:column;gap:.5rem;text-align:center;}
}
</style>
</head>
<body>
<div class="dot-grid"></div>
<div id="cur"></div>
<div id="cur-ring"></div>

<nav>
  <div class="nav-left">
    <div class="nav-logo">ANDRE SHENDRA</div>
    <div class="nav-time" id="clk">LOCAL/ 00:00:00</div>
    <div class="nav-avail"><span class="nav-dot"></span>Available for Work</div>
  </div>
  <div class="nav-right">
    <div class="nav-links">
      <a href="#about">About</a>
      <a href="#projects">Projects</a>
      <a href="#experience">Experience</a>
      <a href="#education">Education</a>
      <a href="#contact">Contact</a>
    </div>
    <a href="#contact" class="nav-hire">Hire Me</a>
  </div>
</nav>

<!-- HERO FULL COVER -->
<section class="hero" id="home">
  <div class="hero-cover"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-tag">Marketing &amp; Events Strategist · Jakarta, Indonesia</div>
    <div class="hero-title">
      ANDRE<br><span class="stroke">SHENDRA</span>
    </div>
  </div>
  <div class="hero-bottom">
    <div class="hero-bottom-cell">
      <span class="hbc-label">Location</span>
      <span class="hbc-value">Jakarta, Indonesia</span>
      <span class="hbc-label" style="margin-top:.5rem;">Available</span>
      <span class="hbc-value">Worldwide</span>
    </div>
    <div class="hero-bottom-cell">
      <div class="hero-desc">Strategic and results-driven event and marketing professional. Founder of Lotus Storia. Creator of high-value brand experiences across fintech, banking, and telecoms.</div>
    </div>
    <div class="hero-bottom-cell">
      <div class="hero-cta">
        <a href="#contact" class="btn-primary">Hire Me</a>
        <a href="#projects" class="btn-ghost">View Work ↗</a>
      </div>
    </div>
  </div>
</section>

<!-- STATS -->
<div class="stats-row">
  <div class="stat-cell"><span class="stat-n">30K+</span><span class="stat-l">Event Attendees</span></div>
  <div class="stat-cell"><span class="stat-n">31</span><span class="stat-l">High-Profile Events</span></div>
  <div class="stat-cell"><span class="stat-n">28+</span><span class="stat-l">Team Members Led</span></div>
  <div class="stat-cell"><span class="stat-n">120%</span><span class="stat-l">First-Year Target</span></div>
</div>

<!-- ABOUT -->
<section id="about">
  <div class="sec-header">
    <span class="sec-num">01 ——</span>
    <span class="sec-title">ABOUT</span>
    <span class="sec-tag">// WHO I AM</span>
  </div>
  <div class="about-grid">
    <div class="about-left">
      <div class="about-img">
        <img src="data:image/png;base64," alt="Andre Shendra">
        <span class="about-img-label">// JAKARTA · 2025</span>
      </div>
      <div class="about-tags">
        <span class="a-tag">Event Strategy</span><span class="a-tag">ROI Optimization</span>
        <span class="a-tag">Brand Activation</span><span class="a-tag">KOL Coordination</span>
        <span class="a-tag">Vendor Negotiation</span><span class="a-tag">B2B Partnerships</span>
        <span class="a-tag">Digital Marketing</span><span class="a-tag">Leadership</span>
        <span class="a-tag">AAJI Certified</span>
      </div>
    </div>
    <div class="about-right">
      <div class="about-headline">I'M ANDREW<br>BASED IN<br>JAKARTA,<br>INDONESIA.</div>
      <div class="about-body">
        <p>Strategic and results-driven event and marketing professional with cross-industry experience in telecommunications, banking, and fintech. With 3 years at Bank Central Asia handling priority clients and driving financial product sales, I bring strong expertise in marketing, sales, and end-to-end execution of impactful online and offline events.</p>
        <p>As the founder of Lotus Storia, I create well-structured, memorable, and high-value brand experiences — from intimate weddings to large-scale corporate events for 30,000+ attendees.</p>
      </div>
      <div class="skills">
        <div class="sk-row"><span>Event Management</span><div class="sk-bar"><div class="sk-fill" style="width:95%"></div></div></div>
        <div class="sk-row"><span>Marketing Strategy</span><div class="sk-bar"><div class="sk-fill" style="width:90%"></div></div></div>
