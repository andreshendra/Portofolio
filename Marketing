<script>
function tick(){const n=new Date(),p=v=>String(v).padStart(2,"0");document.getElementById("clk").textContent="LOCAL/ "+p(n.getHours())+":"+p(n.getMinutes())+":"+p(n.getSeconds());}
tick();setInterval(tick,1000);
const cur=document.getElementById("cur"),ring=document.getElementById("cur-ring");
let mx=0,my=0,rx=0,ry=0;
document.addEventListener("mousemove",e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+"px";cur.style.top=my+"px";});
(function loop(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+"px";ring.style.top=ry+"px";requestAnimationFrame(loop);})();
document.querySelectorAll("a,button,.proj-card,.wid-box").forEach(el=>{
  el.addEventListener("mouseenter",()=>{cur.style.width="5px";cur.style.height="5px";ring.style.width="56px";ring.style.height="56px";});
  el.addEventListener("mouseleave",()=>{cur.style.width="12px";cur.style.height="12px";ring.style.width="40px";ring.style.height="40px";});
});
</script>
